---
import { ShoppingBag } from 'lucide-astro';

const navLinks = [
  { label: 'Inicio', href: '/' },
  { label: 'Productos', href: '/#productos' },
  { label: 'Categorías', href: '/#categorias' },
  { label: 'Confianza', href: '/#confianza' },
];
---

<header id="navbar" class="sticky top-0 z-50 border-b border-white/5 bg-background/80 backdrop-blur-md">
  <nav class="container-app flex h-16 items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0 overflow-visible" aria-label="NOVIXA - Inicio">
      <img src="/logo-novixa.png" alt="NOVIXA Logo" class="h-10 w-auto" style="max-height: 40px;" />
      <span class="font-heading font-extrabold text-lg tracking-tight text-white">NOVIXA</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8 font-subheading text-sm text-muted">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="transition-colors hover:text-white">{link.label}</a>
        </li>
      ))}
    </ul>

    <div class="hidden md:flex items-center gap-3">
      <a
        href="/#productos"
        class="inline-flex items-center gap-2 rounded-xl border border-border px-4 py-2 text-sm font-subheading font-semibold text-white transition-colors hover:border-brand-blue/60"
      >
        <ShoppingBag class="w-4 h-4" strokeWidth={1.75} />
        Ver catálogo
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col items-center justify-center w-10 h-10 gap-1.5 rounded-lg border border-border"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="menu-bar block h-0.5 w-5 bg-white transition-transform duration-200"></span>
      <span class="menu-bar block h-0.5 w-5 bg-white transition-opacity duration-200"></span>
      <span class="menu-bar block h-0.5 w-5 bg-white transition-transform duration-200"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden max-h-0 overflow-hidden border-t border-white/5 bg-background transition-[max-height] duration-300 ease-in-out"
  >
    <ul class="container-app flex flex-col gap-1 py-4 font-subheading text-base">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="block rounded-lg px-3 py-3 text-white/90 hover:bg-white/5">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('menu-open');
      toggle.setAttribute('aria-expanded', String(isOpen));

      if (isOpen) {
        menu.style.maxHeight = menu.scrollHeight + 'px';
      } else {
        menu.style.maxHeight = '0px';
      }

      toggle.classList.toggle('menu-active');
    });

    // Cierra el menú al hacer click en un link (mejora UX en mobile)
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.remove('menu-open');
        menu.style.maxHeight = '0px';
        toggle.setAttribute('aria-expanded', 'false');
        toggle.classList.remove('menu-active');
      });
    });
  }
</script>

<style>
  #menu-toggle.menu-active .menu-bar:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  #menu-toggle.menu-active .menu-bar:nth-child(2) {
    opacity: 0;
  }
  #menu-toggle.menu-active .menu-bar:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }
</style>
